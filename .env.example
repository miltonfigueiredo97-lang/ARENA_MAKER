# Supabase — chaves públicas e servidor
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# GitHub App instalada somente no repositório do Arena Maker
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=12345678
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_OWNER=seu-usuario
GITHUB_REPO=arena-maker
GITHUB_BRANCH=main

# E-mails do Supabase autorizados a usar o importador, separados por vírgula
IMPORTER_ALLOWED_EMAILS=seuemail@exemplo.com
